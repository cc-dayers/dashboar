# ── Storage URL ────────────────────────────────────────────────────────────────
# Base URL of your Azure Blob Storage container (no trailing slash, no SAS token).
# Format: https://{account}.blob.core.windows.net/{container}
AZURE_BLOB_BASE_URL=

# ── SAS Token (if your container is private) ───────────────────────────────────
# Paste the SAS token string here — with or without the leading '?'.
# The server appends it to every blob request. Never exposed to the browser.
# Generate one in the Azure portal: Storage account → Shared access signature.
AZURE_SAS_TOKEN=

# ── Per-report-type overrides (optional) ───────────────────────────────────────
# If a report type needs its own container or token, set these.
# Pattern: AZURE_BLOB_{TYPE}_URL and AZURE_SAS_{TYPE}_TOKEN
# Falls back to AZURE_BLOB_BASE_URL / AZURE_SAS_TOKEN if not set.
#
# AZURE_BLOB_INFRASTRUCTURE_URL=
# AZURE_SAS_INFRASTRUCTURE_TOKEN=
#
# AZURE_BLOB_SIMPLE_URL=
# AZURE_SAS_SIMPLE_TOKEN=
#
# AZURE_BLOB_PR_REVIEW_URL=
# AZURE_SAS_PR_REVIEW_TOKEN=

# ── Fixture serving (development / staging only) ───────────────────────────────
# When set, the API will serve local fixture files from fixtures/{type}/{id}.json
# if the request includes ?_fixture={FIXTURE_SECRET}.
# In local dev (scripts/dev-api.ts) any non-empty ?_fixture= value works — no secret needed.
# NEVER share this value or commit it. Generate with: openssl rand -hex 16
FIXTURE_SECRET=
