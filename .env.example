# ── Azure Blob Storage ─────────────────────────────────────────────────────────
# Base URL of your Azure Blob Storage container (no trailing slash, no SAS token).
# Format: https://{account}.blob.core.windows.net/{container}
AZURE_BLOB_BASE_URL=

# Global SAS token — used for any report type that doesn't have a per-type token below.
# With or without the leading '?'. Server-side only; never exposed to the browser.
# Generate in the Azure portal: Storage account → Shared access signature.
AZURE_SAS_TOKEN=

# Per-report-type SAS tokens (optional). Format: "type:token,type:token"
# The type must match a key in REPORT_NAMES. Takes precedence over AZURE_SAS_TOKEN.
# Parsing note: split on the FIRST ':' only, so colons inside SAS timestamps are preserved.
# Commas inside tokens are safe as Azure encodes them as %2C.
# Example:
#   AZURE_SAS_TOKENS=pr-review:sp=r&st=2026-01-01T00:00:00Z&se=2027-01-01T00:00:00Z&sig=...,review-audit:sp=r&st=...
AZURE_SAS_TOKENS=

# ── Report names ───────────────────────────────────────────────────────────────
# Comma-separated list of report entries. Each entry is one of:
#
#   type:path               blob is report.json (falls back to {type}.json if not found)
#   type:path:filename      blob is {filename}.json — explicit, no fallback
#
# The dashboard probes {AZURE_BLOB_BASE_URL}/{path}/{filename}.json for each entry.
# "type" must match a key in the report registry (pr-review, review-audit, etc.).
#
# Examples:
#   REPORT_NAMES=pr-review:reports/pr-review
#   REPORT_NAMES=pr-review:reports/pr-review,review-audit:reports/pr-review:review-audit
REPORT_NAMES=

# ── Auth gate ──────────────────────────────────────────────────────────────────
# When AUTH_HASH is set, the app shows a login screen to all visitors.
# A user's token is: btoa("username:AUTH_HASH") — paste the base64 result as the password.
#
# AUTHORIZED_USERS: comma-separated usernames that are allowed to log in.
# AUTH_HASH: secret hash appended to each username to form the credential.
#   Don = btoa("don:one-does-not-simply-dash-boar")
#   Gabriel = btoa("gabriel:one-does-not-simply-dash-boar")
#   etc.
#
# Leave AUTH_HASH empty (or unset) to disable auth entirely — useful for local dev.
# Rotate access by changing AUTH_HASH; all existing sessions expire immediately.
AUTHORIZED_USERS=
AUTH_HASH=

# ── Fixture serving (development / staging only) ───────────────────────────────
# When set, requests with ?_fixture={FIXTURE_SECRET} are served from local
# fixture files at fixtures/{type}/{id}.json instead of hitting blob storage.
# NEVER share this value or commit it. Generate with: openssl rand -hex 16
FIXTURE_SECRET=
